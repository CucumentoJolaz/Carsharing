# Example deployment profile (HTTP only, nginx reverse proxy, production-like settings).
# Copy to .env and adjust values before first run:
#   cp .env.example .env

COMPOSE_PROJECT_NAME=carsharing-example
HTTP_PORT=8080

POSTGRES_DB=carsharing
POSTGRES_USER=carsharing
POSTGRES_PASSWORD=change-me-use-a-strong-password

DATABASE_ENGINE=postgresql
POSTGRES_HOST=db
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

DJANGO_SECRET_KEY=change-me-generate-a-long-random-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
DJANGO_DEBUG=0
DJANGO_LOG_LEVEL=INFO

# Seed demo cars/users/trips on first startup (idempotent enough for local example).
FILL_DEMO_DATA=1
